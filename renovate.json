{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge patch updates only if CI passes",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "requiredStatusChecks": [],
      "labels": ["auto-merge"]
    },
    {
      "description": "Do not auto-merge major or minor updates",
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false
    }
  ]
}
